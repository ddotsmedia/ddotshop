// DdotsShop — multi-tenant WhatsApp Commerce SaaS
// Every shop-scoped query MUST filter by shopId. Every tenant-scoped query by tenantId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// NextAuth.js standard models (PrismaAdapter expects these names)
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  tenant        Tenant?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  GROWTH
  PRO
  AGENCY
}

model Tenant {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  plan      Plan     @default(STARTER)
  shop      Shop?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Locale {
  EN
  AR
}

model Shop {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug           String   @unique
  name           String
  tagline        String?
  logoUrl        String?
  coverUrl       String?
  whatsappNumber String
  currency       String   @default("AED")
  locale         Locale   @default(EN)
  themeColor     String   @default("#0a5c36")
  isPublished    Boolean  @default(true)
  isVerified     Boolean  @default(false)
  // payments config
  telrStoreId    String?
  telrAuthKey    String?
  stripeSecretKey String?
  upiId          String?
  upiQrUrl       String?
  codEnabled     Boolean  @default(true)
  // notifications
  notifyNewOrder       Boolean @default(true)
  notifyAbandonedCart  Boolean @default(true)
  notifyLowStock       Boolean @default(true)
  lowStockThreshold    Int     @default(5)

  categories     Category[]
  products       Product[]
  orders         Order[]
  customers      Customer[]
  broadcasts     Broadcast[]
  discountCodes  DiscountCode[]
  pageViews      PageView[]
  aiUsageLogs    AIUsageLog[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
}

// ─────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  shopId    String
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  nameAr    String?
  slug      String
  imageUrl  String?
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([shopId, slug])
  @@index([shopId])
}

model Product {
  id            String           @id @default(cuid())
  shopId        String
  shop          Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name          String
  nameAr        String?
  description   String?          @db.Text
  descriptionAr String?          @db.Text
  price         Decimal          @db.Decimal(10, 2)
  comparePrice  Decimal?         @db.Decimal(10, 2)
  images        String[]
  stock         Int              @default(0)
  trackStock    Boolean          @default(true)
  lowStockThreshold Int          @default(5)
  isFeatured    Boolean          @default(false)
  isPublished   Boolean          @default(false)
  variants      ProductVariant[]
  orderItems    OrderItem[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([shopId])
  @@index([shopId, categoryId])
}

// Variant type, e.g. { name: "Size", values: ["S","M","L"] }
model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  values    String[]

  @@index([productId])
}

// ─────────────────────────────────────────────────────────────
// Orders + Customers
// ─────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  TELR
  STRIPE
  UPI
  COD
  WHATSAPP
}

model Order {
  id             String        @id @default(cuid())
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName   String
  customerPhone  String
  customerAddress String?
  notes          String?       @db.Text
  items          OrderItem[]
  subtotal       Decimal       @db.Decimal(10, 2)
  discountCode   String?
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  currency       String        @default("AED")
  status         OrderStatus   @default(PENDING)
  paymentStatus  PaymentStatus @default(PENDING)
  paymentMethod  PaymentMethod @default(WHATSAPP)
  paymentRef     String?
  paidAt         DateTime?
  waMessageSent  Boolean       @default(false)
  invoiceUrl     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([shopId])
  @@index([shopId, status])
  @@index([shopId, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String
  variant   String?
  qty       Int
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(10, 2)
  image     String?

  @@index([orderId])
}

model Customer {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String?
  phone       String
  email       String?
  address     String?
  notes       String?  @db.Text
  tags        String[]
  totalOrders Int      @default(0)
  totalSpent  Decimal  @default(0) @db.Decimal(12, 2)
  lastOrderAt DateTime?
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, phone])
  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// Marketing
// ─────────────────────────────────────────────────────────────

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model Broadcast {
  id          String          @id @default(cuid())
  shopId      String
  shop        Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  message     String          @db.Text
  mediaUrl    String?
  status      BroadcastStatus @default(DRAFT)
  targetTags  String[]
  targetCount Int             @default(0)
  sentCount   Int             @default(0)
  failedCount Int             @default(0)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime        @default(now())

  @@index([shopId])
}

enum DiscountType {
  PERCENT
  FIXED
}

model DiscountCode {
  id        String       @id @default(cuid())
  shopId    String
  shop      Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  code      String
  type      DiscountType @default(PERCENT)
  value     Decimal      @db.Decimal(10, 2)
  minOrder  Decimal      @default(0) @db.Decimal(10, 2)
  maxUses   Int?
  usedCount Int          @default(0)
  isActive  Boolean      @default(true)
  expiresAt DateTime?
  createdAt DateTime     @default(now())

  @@unique([shopId, code])
  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// Analytics + AI metering
// ─────────────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  path      String
  device    String?
  country   String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([shopId, createdAt])
}

model AIUsageLog {
  id           String   @id @default(cuid())
  shopId       String?
  shop         Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  tenantId     String?
  feature      String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  cost         Decimal  @default(0) @db.Decimal(10, 6)
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([shopId, createdAt])
}
