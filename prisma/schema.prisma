// DdotsShop — multi-tenant WhatsApp Commerce SaaS
// Every shop-scoped query MUST filter by shopId. Every tenant-scoped query by tenantId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// NextAuth.js standard models (PrismaAdapter expects these names)
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role            String    @default("TENANT")
  isSuspended     Boolean   @default(false)
  suspendedAt     DateTime?
  suspendedReason String?
  lastLoginAt     DateTime?
  loginCount      Int       @default(0)
  adminNotes      String?   @db.Text
  createdByAdmin  Boolean   @default(false)
  accounts      Account[]
  sessions      Session[]
  tenant        Tenant?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Tenancy
// ─────────────────────────────────────────────────────────────

enum Plan {
  STARTER
  GROWTH
  PRO
  AGENCY
}

model Tenant {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  plan      Plan     @default(STARTER)
  shop      Shop?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Locale {
  EN
  AR
  ML
  HI
}

model Shop {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug           String   @unique
  name           String
  tagline        String?
  logoUrl        String?
  coverUrl       String?
  whatsappNumber String
  currency       String   @default("AED")
  locale         Locale   @default(EN)
  themeColor     String   @default("#0a5c36")
  isPublished    Boolean  @default(true)
  isVerified     Boolean  @default(false)
  // payments config
  telrStoreId    String?
  telrAuthKey    String?
  stripeSecretKey String?
  upiId          String?
  upiQrUrl       String?
  codEnabled     Boolean  @default(true)
  // notifications
  notifyNewOrder       Boolean @default(true)
  notifyAbandonedCart  Boolean @default(true)
  notifyLowStock       Boolean @default(true)
  lowStockThreshold    Int     @default(5)

  categories     Category[]
  products       Product[]
  orders         Order[]
  customers      Customer[]
  broadcasts     Broadcast[]
  discountCodes  DiscountCode[]
  pageViews      PageView[]
  aiUsageLogs    AIUsageLog[]
  loyaltyProgram LoyaltyProgram?
  flowTemplates  WAFlowTemplate[]
  notifyReviewRequest Boolean @default(true)
  flashSales     FlashSale[]
  bundles        ProductBundle[]
  giftCards      GiftCard[]
  vatConfig      VATConfig?
  wholesaleCustomers WholesaleCustomer[]
  vendors        Vendor[]
  ctwaCampaigns  CTWACampaign[]
  freeShippingThreshold Decimal? @db.Decimal(10, 2)
  shippingFlatRate      Decimal  @default(0) @db.Decimal(10, 2)
  region          String   @default("UAE")
  taxType         String   @default("NONE")
  taxRate         Decimal  @default(0) @db.Decimal(5, 2)
  taxNumber       String?
  razorpayKeyId   String?
  razorpaySecret  String?
  shiprocketToken String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
}

// ─────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  shopId    String
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  nameAr    String?
  slug      String
  imageUrl  String?
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([shopId, slug])
  @@index([shopId])
}

model Product {
  id            String           @id @default(cuid())
  shopId        String
  shop          Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name          String
  nameAr        String?
  description   String?          @db.Text
  descriptionAr String?          @db.Text
  descriptionMl String?          @db.Text
  descriptionHi String?          @db.Text
  price         Decimal          @db.Decimal(10, 2)
  comparePrice  Decimal?         @db.Decimal(10, 2)
  images        String[]
  stock         Int              @default(0)
  trackStock    Boolean          @default(true)
  lowStockThreshold Int          @default(5)
  isFeatured    Boolean          @default(false)
  isPublished   Boolean          @default(false)
  isPreOrder    Boolean          @default(false)
  preOrderDeposit Decimal?       @db.Decimal(10, 2)
  allowSubscription Boolean      @default(false)
  wholesalePrice Decimal?        @db.Decimal(10, 2)
  moqQty        Int?
  vendorId      String?
  vendor        Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  variants      ProductVariant[]
  orderItems    OrderItem[]
  reviews       ProductReview[]
  flashSaleItems FlashSaleProduct[]
  bundleItems   BundleItem[]
  wishlists     Wishlist[]
  preOrders     PreOrder[]
  waitlists     Waitlist[]
  subscriptions2 Subscription2[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([shopId])
  @@index([shopId, categoryId])
  @@index([vendorId])
}

// Variant type, e.g. { name: "Size", values: ["S","M","L"] }
model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  values    String[]

  @@index([productId])
}

// ─────────────────────────────────────────────────────────────
// Orders + Customers
// ─────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  TELR
  STRIPE
  UPI
  COD
  WHATSAPP
  RAZORPAY
}

model Order {
  id             String        @id @default(cuid())
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName   String
  customerPhone  String
  customerAddress String?
  notes          String?       @db.Text
  items          OrderItem[]
  subtotal       Decimal       @db.Decimal(10, 2)
  discountCode   String?
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  currency       String        @default("AED")
  status         OrderStatus   @default(PENDING)
  paymentStatus  PaymentStatus @default(PENDING)
  paymentMethod  PaymentMethod @default(WHATSAPP)
  paymentRef     String?
  paidAt         DateTime?
  waMessageSent  Boolean       @default(false)
  invoiceUrl     String?
  source         String        @default("web")
  voiceOrderId   String?
  reviewRequested Boolean      @default(false)
  vatAmount      Decimal       @default(0) @db.Decimal(10, 2)
  vatRate        Decimal       @default(0) @db.Decimal(5, 2)
  shippingCost   Decimal       @default(0) @db.Decimal(10, 2)
  awb            String?
  shipmentId     String?
  courier        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([shopId])
  @@index([shopId, status])
  @@index([shopId, createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name      String
  variant   String?
  qty       Int
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(10, 2)
  image     String?

  @@index([orderId])
}

model Customer {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String?
  phone       String
  email       String?
  address     String?
  notes       String?  @db.Text
  tags        String[]
  totalOrders Int      @default(0)
  totalSpent  Decimal  @default(0) @db.Decimal(12, 2)
  lastOrderAt DateTime?
  orders      Order[]
  points      CustomerPoints?
  reviews     ProductReview[]
  subscriptions2 Subscription2[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, phone])
  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// Marketing
// ─────────────────────────────────────────────────────────────

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model Broadcast {
  id          String          @id @default(cuid())
  shopId      String
  shop        Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  message     String          @db.Text
  mediaUrl    String?
  status      BroadcastStatus @default(DRAFT)
  targetTags  String[]
  targetCount Int             @default(0)
  sentCount   Int             @default(0)
  failedCount Int             @default(0)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime        @default(now())

  @@index([shopId])
}

enum DiscountType {
  PERCENT
  FIXED
  BOGO
}

model DiscountCode {
  id        String       @id @default(cuid())
  shopId    String
  shop      Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  code      String
  type      DiscountType @default(PERCENT)
  value     Decimal      @db.Decimal(10, 2)
  minOrder  Decimal      @default(0) @db.Decimal(10, 2)
  maxUses   Int?
  usedCount Int          @default(0)
  isActive  Boolean      @default(true)
  expiresAt DateTime?
  createdAt DateTime     @default(now())

  @@unique([shopId, code])
  @@index([shopId])
}

// ─────────────────────────────────────────────────────────────
// Analytics + AI metering
// ─────────────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  path      String
  device    String?
  country   String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([shopId, createdAt])
}

model AIUsageLog {
  id           String   @id @default(cuid())
  shopId       String?
  shop         Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  tenantId     String?
  feature      String
  model        String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  cost         Decimal  @default(0) @db.Decimal(10, 6)
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([shopId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Reviews · Loyalty · Referral · Voice · WA Flows
// ─────────────────────────────────────────────────────────────

model ProductReview {
  id          String    @id @default(cuid())
  shopId      String
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  rating      Int
  body        String?
  source      String    @default("whatsapp")
  approved    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([productId])
  @@index([shopId])
  @@map("product_reviews")
}

model LoyaltyProgram {
  id               String   @id @default(cuid())
  shopId           String   @unique
  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  pointsPerAED     Int      @default(1)
  rewardThreshold  Int      @default(200)
  rewardValue      Decimal  @default(10) @db.Decimal(10, 2)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@map("loyalty_programs")
}

model CustomerPoints {
  id         String   @id @default(cuid())
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shopId     String
  points     Int      @default(0)
  lifetime   Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([customerId, shopId])
  @@map("customer_points")
}

model LoyaltyTransaction {
  id         String   @id @default(cuid())
  customerId String
  shopId     String
  points     Int
  type       String
  orderId    String?
  note       String?
  createdAt  DateTime @default(now())

  @@index([customerId, shopId])
  @@map("loyalty_transactions")
}

model ReferralLink {
  id          String   @id @default(cuid())
  customerId  String
  shopId      String
  code        String   @unique
  clicks      Int      @default(0)
  conversions Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([shopId])
  @@map("referral_links")
}

model VoiceOrder {
  id            String   @id @default(cuid())
  shopId        String
  customerPhone String
  audioUrl      String
  transcript    String?
  parsedItems   Json?
  status        String   @default("PENDING")
  orderId       String?
  createdAt     DateTime @default(now())

  @@index([shopId])
  @@map("voice_orders")
}

model WAFlowTemplate {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name       String
  flowJson   Json
  type       String
  metaFlowId String?
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([shopId])
  @@map("wa_flow_templates")
}

// ─────────────────────────────────────────────────────────────
// Advanced ecommerce (Phases 17–24)
// ─────────────────────────────────────────────────────────────

model FlashSale {
  id        String             @id @default(cuid())
  shopId    String
  shop      Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean            @default(false)
  products  FlashSaleProduct[]
  createdAt DateTime           @default(now())

  @@index([shopId])
  @@map("flash_sales")
}

model FlashSaleProduct {
  id          String    @id @default(cuid())
  flashSaleId String
  flashSale   FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  salePrice   Decimal   @db.Decimal(10, 2)

  @@map("flash_sale_products")
}

model ProductBundle {
  id          String       @id @default(cuid())
  shopId      String
  shop        Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  description String?
  bundlePrice Decimal      @db.Decimal(10, 2)
  isActive    Boolean      @default(true)
  imageUrl    String?
  items       BundleItem[]
  createdAt   DateTime     @default(now())

  @@index([shopId])
  @@map("product_bundles")
}

model BundleItem {
  id        String        @id @default(cuid())
  bundleId  String
  bundle    ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  qty       Int           @default(1)

  @@map("bundle_items")
}

model GiftCard {
  id             String    @id @default(cuid())
  shopId         String
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  code           String    @unique
  initialValue   Decimal   @db.Decimal(10, 2)
  balance        Decimal   @db.Decimal(10, 2)
  currency       String    @default("AED")
  recipientEmail String?
  recipientName  String?
  message        String?
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  purchasedBy    String?
  createdAt      DateTime  @default(now())

  @@index([shopId])
  @@index([code])
  @@map("gift_cards")
}

model Wishlist {
  id            String   @id @default(cuid())
  shopId        String
  customerPhone String
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  notifyOnDrop  Boolean  @default(false)
  notifyOnStock Boolean  @default(true)
  addedAt       DateTime @default(now())

  @@unique([shopId, customerPhone, productId])
  @@index([shopId])
  @@map("wishlists")
}

model Subscription2 {
  id           String   @id @default(cuid())
  shopId       String
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  intervalDays Int      @default(30)
  nextOrderAt  DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([shopId])
  @@index([nextOrderAt])
  @@map("subscriptions2")
}

model PreOrder {
  id            String    @id @default(cuid())
  shopId        String
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerPhone String
  customerName  String?
  depositPaid   Decimal   @db.Decimal(10, 2)
  totalPrice    Decimal   @db.Decimal(10, 2)
  status        String    @default("PENDING")
  expectedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([shopId])
  @@map("pre_orders")
}

model Waitlist {
  id            String   @id @default(cuid())
  shopId        String
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerPhone String
  customerName  String?
  notified      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@unique([shopId, productId, customerPhone])
  @@index([shopId, productId])
  @@map("waitlists")
}

model VATConfig {
  id        String  @id @default(cuid())
  shopId    String  @unique
  shop      Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  enabled   Boolean @default(false)
  rate      Decimal @default(5) @db.Decimal(5, 2)
  vatNumber String?

  @@map("vat_configs")
}

model RegionPricing {
  id       String  @id @default(cuid())
  region   String  @unique
  starter  Decimal @db.Decimal(10, 2)
  growth   Decimal @db.Decimal(10, 2)
  pro      Decimal @db.Decimal(10, 2)
  agency   Decimal @db.Decimal(10, 2)
  currency String

  @@map("region_pricing")
}

// ─────────────────────────────────────────────────────────────
// Super Admin
// ─────────────────────────────────────────────────────────────

model AdminAction {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  details    Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_actions")
}

model PlatformAnnouncement {
  id        String    @id @default(cuid())
  title     String
  body      String    @db.Text
  type      String    @default("INFO")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@map("platform_announcements")
}

// ─────────────────────────────────────────────────────────────
// B2B Wholesale + Multi-vendor + CTWA
// ─────────────────────────────────────────────────────────────

model WholesaleCustomer {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerPhone String
  customerName  String?
  company       String?
  isApproved    Boolean  @default(false)
  discountPct   Decimal  @default(0) @db.Decimal(5, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shopId, customerPhone])
  @@index([shopId])
  @@map("wholesale_customers")
}

model Vendor {
  id            String    @id @default(cuid())
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name          String
  email         String?
  phone         String?
  commissionPct Decimal   @default(0) @db.Decimal(5, 2)
  payoutAccount String?
  isActive      Boolean   @default(true)
  products      Product[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shopId])
  @@map("vendors")
}

model CTWACampaign {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name        String
  utmSource   String
  utmMedium   String?
  utmCampaign String?
  clicks      Int      @default(0)
  orders      Int      @default(0)
  revenue     Decimal  @default(0) @db.Decimal(12, 2)
  spend       Decimal  @default(0) @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, utmSource])
  @@index([shopId])
  @@map("ctwa_campaigns")
}
